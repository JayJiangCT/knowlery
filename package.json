{
  "name": "knowlery",
  "version": "0.6.0",
  "description": "A warm personal knowledge review space for your vault.",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "lint": "eslint src",
    "docs:dev": "vitepress dev docs-site",
    "docs:build": "vitepress build docs-site",
    "docs:preview": "vitepress preview docs-site",
    "test": "vitest run --dir tests",
    "test:watch": "vitest --dir tests",
    "eval": "tsx evals/src/run.ts"
  },
  "keywords": [
    "obsidian",
    "obsidian-plugin"
  ],
  "author": "Jay Jiang",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.19.41",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "esbuild": "^0.28.0",
    "eslint": "^9.39.4",
    "eslint-plugin-obsidianmd": "^0.3.0",
    "gray-matter": "^4.0.0",
    "obsidian": "latest",
    "playwright": "^1.60.0",
    "semver": "^7.7.4",
    "tslib": "^2.6.0",
    "tsx": "^4.22.5",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.59.4",
    "vitepress": "^2.0.0-alpha.17",
    "vitest": "^4.1.7",
    "yaml": "^2.9.0"
  },
  "dependencies": {
    "jszip": "^3.10.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "zod": "^3.23.0"
  }
}
